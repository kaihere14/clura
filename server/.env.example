# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/clura

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/callback
GLOBAL_REDIRECT_URI=http://localhost:8000/v1/global-auth/callback

# JWT Secret for session tokens (HS256)
JWT_SECRET=your_jwt_secret_key

# JWT RSA Config for Global Auth (RS256)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_KEY_ID=your_key_id
JWT_ISSUER=clura-auth

# Frontend URL for redirects
FRONTEND_URL=http://localhost:3000
